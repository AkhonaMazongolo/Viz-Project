// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String @id @default(cuid())
  userId            Int
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String @id @default(cuid())
  sessionToken String @unique
  userId       Int
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String?
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  documents     Document[]

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Conversation {
  id        Int        @id @default(autoincrement())
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  messages  Message[]
  documents Document[]
}

model Message {
  id Int @id @default(autoincrement())

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  role      String
  content   String
  createdAt DateTime @default(now())
}

model Document {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  fileName     String
  originalName String
  filePath     String

  documentType DocumentType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  glDocuments    GLDocument[]
  visualizations Visualization[]
  insights       Insight[]
  chunks         DocumentChunk[]
  trialBalances  TrialBalance[]
}

model GLDocument {
  id                   Int       @id @default(autoincrement())
  accountNumber        Int?
  reference            String?
  contactAccount       String?
  description          String?
  debit                Float?
  credit               Float?
  balance              Float?
  monthName            String?
  categoryName         String?
  rootName             String?
  subCategoryName      String?
  fsaName              String?
  subFsaName           String?
  material             Int?
  randMaterial         Float?
  amount               Float?
  departmentCode       String?
  dimensionSetID       Int?
  paypointCode         Int?
  genPostingType       String?
  genBusPostingGroup   String?
  balanceAccountType   String?
  balanceAccountNumber Int?
  entryNo              Int?
  externalDocumentNo   String?
  accountName          String?
  jobTypeCode          Int?
  documentType         String?
  genProdOPostingGroup String?
  letter               String?
  letterDate           DateTime?
  vendorTypeCode       String?
  itemCategoryCode     String?
  productTypeCode      String?
  expenseSplitCode     String?
  trialCode            String?
  resourseCode         String?
  userID               String?
  date                 DateTime?
  glAccountName        String?
  vatAmount            Float?

  documentID   Int
  conversation Document @relation(fields: [documentID], references: [id])
}

model TrialBalance {
  id            Int     @id @default(autoincrement())
  accountNumber String?
  accountType   String?
  branch        Int?
  dept          String?
  debits        Float?
  credits       Float?
  PYDebits      Float?
  PYCredits     Float?

  documentID   Int
  conversation Document @relation(fields: [documentID], references: [id])
}

model Visualization {
  id Int @id @default(autoincrement())

  documentId Int
  document   Document @relation(fields: [documentId], references: [id])

  title String

  chartType ChartType

  prompt String?

  config Json

  createdAt DateTime @default(now())
}

model Insight {
  id Int @id @default(autoincrement())

  documentId Int

  document Document @relation(fields: [documentId], references: [id])

  title String

  description String

  metricValue Float?

  createdAt DateTime @default(now())
}

model DocumentChunk {
  id Int @id @default(autoincrement())

  documentId Int

  document Document @relation(fields: [documentId], references: [id])

  content String

  embeddingId String?

  pageNumber Int?
}

enum ChartType {
  BAR
  LINE
  PIE
  TREEMAP
  SANKEY
  WATERFALL
  HEATMAP
}

enum DocumentType {
  GENERAL_LEDGER
  TRIAL_BALANCE
  JOURNAL_ENTRY
  AP_AGING
  AR_AGING
  BANK_STATEMENT
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
